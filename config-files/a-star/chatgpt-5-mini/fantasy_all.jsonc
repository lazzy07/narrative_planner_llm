{
  "search": {
    // Search configurations
    "type": {
      "name": "best-first", // Options: breadth-first
      "config": {}
    },
    "cost": {
      "type": "plan-length", // Options: none
      "config": {}
    },
    "heuristic": {
      "type": "rp",
      "config": {}
    },
    "plan": {
      "max-length": 11, // Max length of the plan until the planner should stop if no solution is found.
      "utility": 3, // Utility that planner needs to achieve.
      "max-nodes": 5000
    }
  },
  "llm": {
    // LLM API Configurations
    "prompt": {
      "version": "v1.3",
      "directory": "prompt-templates/",
      "explanation": true // Append the explanation (from the LLM) why that action was taken.
    },
    "cache": {
      "enabled": true,
      "directory": ".openai-cache/"
    },
    "model": {
      "name": "chatgpt-5-mini",
      "config": {}
    }
  },
  "domain": {
    // Domain configurations
    "name": "fantasy_all",
    "file": "problems/fantasy.txt"
  },
  "output": {
    "save": true,
    "directory": "output/"
  }
}
