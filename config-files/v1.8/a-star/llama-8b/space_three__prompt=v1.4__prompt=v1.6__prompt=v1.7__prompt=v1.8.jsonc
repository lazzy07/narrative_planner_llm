{
  "domain": {
    "file": "problems/space.txt",
    "name": "space_three"
  },
  "llm": {
    "cache": {
      "directory": ".llama-8b-cache/",
      "enabled": true
    },
    "model": {
      "config": {},
      "name": "llama-8b"
    },
    "prompt": {
      "directory": "prompt-templates/",
      "explanation": true,
      "version": "v1.8"
    }
  },
  "output": {
    "directory": "output/",
    "save": true
  },
  "search": {
    "cost": {
      "config": {},
      "type": "plan-length"
    },
    "heuristic": {
      "config": {},
      "type": "rp"
    },
    "plan": {
      "max-length": 5,
      "max-nodes": 5000,
      "utility": 3
    },
    "type": {
      "config": {},
      "name": "best-first"
    }
  }
}
