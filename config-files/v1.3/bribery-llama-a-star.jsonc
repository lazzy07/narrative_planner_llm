{
  "search": {
    // Search configurations
    "type": {
      "name": "best-first", // Options: breadth-first
      "config": {},
    },
    "cost": {
      "type": "plan-length", // Options: none
      "config": {},
    },
    "heuristic": {
      "type": "rp",
      "config": {},
    },
    "plan": {
      "max-length": 7, // Max length of the plan untill the planner should stop, if planner did not find a solution.
      "utility": 1, // Utility that planner needs to achieve.
      "max-nodes": 5000,
    },
  },
  "llm": {
    // LLM API Configurations
    "prompt": {
      "version": "v1.3",
      "directory": "prompt-templates/",
      "explanation": true, // Append the explaination to (coming from the LLM) why that action was taken.
    },
    "cache": {
      "enabled": true,
      "directory": ".llama-8b-cache/",
    },
    "model": {
      "name": "llama-8b",
      "config": {},
    },
  },
  "domain": {
    // Domain configurations
    "name": "bribery",
    "file": "problems/bribery.txt",
  },
  "output": {
    "save": true,
    "directory": "output/",
  },
}
